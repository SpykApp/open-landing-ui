extends layouts/base

block vars
  - activePage = 'pricing'
  - pageTitle = 'Pricing'
  - pageDescription = 'SpykApps pricing plans - Simple, transparent pricing for businesses of all sizes. Start your free trial today.'

block content
  section.page-header
    .container
      h1 Simple, Transparent Pricing
      p.lead Choose the plan that fits your business. No hidden fees, no surprises.
      nav(aria-label='breadcrumb')
        ol.breadcrumb
          li.breadcrumb-item: a(href='index.html') Home
          li.breadcrumb-item.active(aria-current='page') Pricing

  section.pricing.section-lg
    .container
      .pricing-toggle
        span.pricing-toggle-label.active(data-period='monthly') Monthly
        .pricing-toggle-switch
        span.pricing-toggle-label(data-period='yearly') Yearly
        span.pricing-save Save 20%

      .row.g-4.justify-content-center
        .col-lg-4.col-md-6
          .pricing-card.animate-on-scroll
            span.pricing-plan Starter
            h3 For Small Teams
            .pricing-price
              span.pricing-amount.price-monthly
                sup $
                | 29
              span.pricing-amount.price-yearly(style='display: none;')
                sup $
                | 23
              span.pricing-period per user / month
            p.pricing-desc Perfect for small businesses just getting started with workforce management.
            ul.pricing-features
              li: i.bi.bi-check-circle-fill
                |  Up to 25 employees
              li: i.bi.bi-check-circle-fill
                |  Basic scheduling
              li: i.bi.bi-check-circle-fill
                |  Time tracking
              li: i.bi.bi-check-circle-fill
                |  Mobile app access
              li: i.bi.bi-check-circle-fill
                |  Email support
              li: i.bi.bi-check-circle-fill
                |  Basic reporting
              li.disabled: i.bi.bi-x-circle
                |  Payroll processing
              li.disabled: i.bi.bi-x-circle
                |  Advanced analytics
              li.disabled: i.bi.bi-x-circle
                |  API access
            a.btn.btn-outline-primary(href='#') Start Free Trial

        .col-lg-4.col-md-6
          .pricing-card.popular.animate-on-scroll.delay-1
            span.pricing-badge Most Popular
            span.pricing-plan Professional
            h3 For Growing Teams
            .pricing-price
              span.pricing-amount.price-monthly
                sup $
                | 59
              span.pricing-amount.price-yearly(style='display: none;')
                sup $
                | 47
              span.pricing-period per user / month
            p.pricing-desc Everything you need to manage and scale your growing workforce.
            ul.pricing-features
              li: i.bi.bi-check-circle-fill
                |  Up to 100 employees
              li: i.bi.bi-check-circle-fill
                |  Advanced scheduling
              li: i.bi.bi-check-circle-fill
                |  Time tracking + GPS
              li: i.bi.bi-check-circle-fill
                |  Payroll processing
              li: i.bi.bi-check-circle-fill
                |  Compliance alerts
              li: i.bi.bi-check-circle-fill
                |  Analytics dashboard
              li: i.bi.bi-check-circle-fill
                |  Priority support
              li: i.bi.bi-check-circle-fill
                |  Integrations
              li.disabled: i.bi.bi-x-circle
                |  Custom reporting
            a.btn.btn-primary(href='#') Start Free Trial

        .col-lg-4.col-md-6
          .pricing-card.animate-on-scroll.delay-2
            span.pricing-plan Enterprise
            h3 For Large Organizations
            .pricing-price
              span.pricing-amount Custom
              span.pricing-period tailored to your needs
            p.pricing-desc Custom solutions for enterprise-level workforce management needs.
            ul.pricing-features
              li: i.bi.bi-check-circle-fill
                |  Unlimited employees
              li: i.bi.bi-check-circle-fill
                |  Custom integrations
              li: i.bi.bi-check-circle-fill
                |  Advanced security
              li: i.bi.bi-check-circle-fill
                |  Dedicated success manager
              li: i.bi.bi-check-circle-fill
                |  Custom reporting
              li: i.bi.bi-check-circle-fill
                |  SLA guarantee
              li: i.bi.bi-check-circle-fill
                |  On-site training
              li: i.bi.bi-check-circle-fill
                |  API access
              li: i.bi.bi-check-circle-fill
                |  White-label options
            a.btn.btn-dark(href='contact.html') Contact Sales

  section.py-5.bg-light-soft
    .container.py-5
      .section-title
        span.subtitle Compare Plans
        h2 Feature Comparison
        p See exactly what's included in each plan
      .table-responsive
        table.table.table-bordered.bg-white(style='border-radius: var(--ss-radius-lg); overflow: hidden;')
          thead(style='background: var(--ss-dark); color: white;')
            tr
              th(style='width: 30%;') Feature
              th.text-center Starter
              th.text-center(style='background: var(--ss-primary);') Professional
              th.text-center Enterprise
          tbody
            tr
              td: strong Employees
              td.text-center Up to 25
              td.text-center Up to 100
              td.text-center Unlimited
            tr
              td: strong Scheduling
              td.text-center Basic
              td.text-center Advanced + AI
              td.text-center Custom
            tr
              td: strong Time Tracking
              td.text-center: i.bi.bi-check-lg.text-success
              td.text-center
                i.bi.bi-check-lg.text-success
                |  + GPS
              td.text-center
                i.bi.bi-check-lg.text-success
                |  + Biometric
            tr
              td: strong Payroll Processing
              td.text-center: i.bi.bi-x-lg.text-danger
              td.text-center: i.bi.bi-check-lg.text-success
              td.text-center: i.bi.bi-check-lg.text-success
            tr
              td: strong Mobile App
              td.text-center: i.bi.bi-check-lg.text-success
              td.text-center: i.bi.bi-check-lg.text-success
              td.text-center: i.bi.bi-check-lg.text-success
            tr
              td: strong Compliance Alerts
              td.text-center: i.bi.bi-x-lg.text-danger
              td.text-center: i.bi.bi-check-lg.text-success
              td.text-center: i.bi.bi-check-lg.text-success
            tr
              td: strong Analytics
              td.text-center Basic
              td.text-center Advanced
              td.text-center Custom
            tr
              td: strong Integrations
              td.text-center 3
              td.text-center 20+
              td.text-center Unlimited + Custom
            tr
              td: strong API Access
              td.text-center: i.bi.bi-x-lg.text-danger
              td.text-center: i.bi.bi-x-lg.text-danger
              td.text-center: i.bi.bi-check-lg.text-success
            tr
              td: strong Support
              td.text-center Email
              td.text-center Priority
              td.text-center Dedicated Manager

  section.faq
    .container
      .section-title
        span.subtitle FAQ
        h2 Pricing Questions
      .faq-grid
        .accordion#pricingFaq
          .accordion-item
            h2.accordion-header
              button.accordion-button(type='button' data-bs-toggle='collapse' data-bs-target='#pf1') Can I change plans at any time?
            #pf1.accordion-collapse.collapse.show(data-bs-parent='#pricingFaq')
              .accordion-body Yes! You can upgrade or downgrade your plan at any time. When upgrading, you'll get immediate access to new features. When downgrading, changes take effect at your next billing cycle.
          .accordion-item
            h2.accordion-header
              button.accordion-button.collapsed(type='button' data-bs-toggle='collapse' data-bs-target='#pf2') Is there a setup fee?
            #pf2.accordion-collapse.collapse(data-bs-parent='#pricingFaq')
              .accordion-body No setup fees for Starter and Professional plans. Enterprise plans may include implementation services which are quoted based on your specific requirements.
          .accordion-item
            h2.accordion-header
              button.accordion-button.collapsed(type='button' data-bs-toggle='collapse' data-bs-target='#pf3') What payment methods do you accept?
            #pf3.accordion-collapse.collapse(data-bs-parent='#pricingFaq')
              .accordion-body We accept all major credit cards (Visa, MasterCard, American Express), ACH bank transfers, and wire transfers for Enterprise customers.
          .accordion-item
            h2.accordion-header
              button.accordion-button.collapsed(type='button' data-bs-toggle='collapse' data-bs-target='#pf4') Do you offer discounts for nonprofits?
            #pf4.accordion-collapse.collapse(data-bs-parent='#pricingFaq')
              .accordion-body Yes, we offer 25% off for registered nonprofit organizations. Contact our sales team with your 501(c)(3) documentation to get started.

  section.cta-section
    .container
      .cta-content
        h2 Start Your Free 14-Day Trial
        p No credit card required. Full access to all features.
        a.btn.btn-lg(href='#' style='background: white; color: var(--ss-primary);') Get Started Free
