extends layouts/base

block vars
  - activePage = 'about'
  - pageTitle = 'About Us'
  - pageDescription = 'About SpykApps - Learn about our mission to transform workforce management.'

block content
  section.page-header
    .container
      h1 About SpykApps
      p.lead Transforming how businesses manage their workforce since 2018
      nav(aria-label='breadcrumb')
        ol.breadcrumb
          li.breadcrumb-item: a(href='index.html') Home
          li.breadcrumb-item.active About

  section.py-5
    .container.py-5
      .row.align-items-center
        .col-lg-6.mb-4.mb-lg-0
          span.subtitle.d-inline-block.mb-3(style='background: var(--ss-bg-purple-light); padding: 0.5rem 1rem; border-radius: 50px; font-size: 0.875rem; color: var(--ss-primary); font-weight: 600;') OUR STORY
          h2 Built by People Who Understand Workforce Challenges
          p.lead.text-muted SpykApps was born from frustration with outdated, fragmented workforce management tools.
          p In 2018, our founders—former HR directors and operations managers—set out to build the platform they wished they had. They understood the pain of juggling spreadsheets, paper timesheets, and disconnected systems.
          p Today, SpykApps serves over 5,000 companies worldwide, from small restaurants to enterprise healthcare organizations. Our mission remains the same: make workforce management simple, accurate, and fair for everyone.
        .col-lg-6
          svg(viewBox='0 0 500 400' class='img-fluid')
            rect(width='500' height='400' rx='20' fill='#F8F9FA')
            rect(x='40' y='40' width='420' height='320' rx='16' fill='white' stroke='#E9ECEF' stroke-width='2')
            circle(cx='150' cy='180' r='60' fill='#6B5CE7' opacity='0.2')
            circle(cx='350' cy='180' r='60' fill='#FF6B6B' opacity='0.2')
            circle(cx='250' cy='220' r='60' fill='#4A90E2' opacity='0.2')
            rect(x='100' y='280' width='300' height='40' rx='20' fill='#6B5CE7')
            text(x='250' y='307' font-family='Poppins' font-size='14' font-weight='600' fill='white' text-anchor='middle') Team Collaboration

  section.py-5.bg-light-soft
    .container.py-5
      .row.text-center.g-4
        .col-6.col-lg-3
          .p-4
            div(class='display-4 fw-bold text-primary counter' data-target='5000') 0
            p.text-muted.mb-0 Companies Trust Us
        .col-6.col-lg-3
          .p-4
            .display-4.fw-bold.text-primary
              span.counter(data-target='500') 0
              | K+
            p.text-muted.mb-0 Employees Managed
        .col-6.col-lg-3
          .p-4
            .display-4.fw-bold.text-primary
              span.counter(data-target='50') 0
              | +
            p.text-muted.mb-0 Countries Served
        .col-6.col-lg-3
          .p-4
            .display-4.fw-bold.text-primary
              span.counter(data-target='98') 0
              | %
            p.text-muted.mb-0 Customer Satisfaction

  section.py-5
    .container.py-5
      .section-title
        span.subtitle Our Values
        h2 What Drives Us Every Day
      .row.g-4
        .col-md-6.col-lg-4
          .feature-card.animate-on-scroll
            .feature-icon.icon-purple: i.bi.bi-lightbulb
            h4 Innovation
            p We constantly push boundaries to deliver cutting-edge solutions that anticipate our customers' needs.
        .col-md-6.col-lg-4
          .feature-card.animate-on-scroll.delay-1
            .feature-icon.icon-green: i.bi.bi-people
            h4 Customer First
            p Every decision we make starts with asking, "How does this benefit our customers?"
        .col-md-6.col-lg-4
          .feature-card.animate-on-scroll.delay-2
            .feature-icon.icon-blue: i.bi.bi-shield-check
            h4 Trust & Security
            p We protect your data like it's our own, with enterprise-grade security and transparent practices.

  section.py-5.bg-light-soft
    .container.py-5
      .section-title
        span.subtitle Leadership
        h2 Meet Our Team
      .row.g-4.justify-content-center
        .col-lg-3.col-md-6
          .team-card.animate-on-scroll
            .team-card-image(style='background: linear-gradient(135deg, #6B5CE7, #8B7DF2); display: flex; align-items: center; justify-content: center; color: white; font-size: 3rem; font-weight: 600;') JC
            h4 Jennifer Chen
            p CEO &amp; Co-founder
            .team-social
              a(href='#'): i.bi.bi-linkedin
              a(href='#'): i.bi.bi-twitter-x
        .col-lg-3.col-md-6
          .team-card.animate-on-scroll.delay-1
            .team-card-image(style='background: linear-gradient(135deg, #4A90E2, #6BA8EE); display: flex; align-items: center; justify-content: center; color: white; font-size: 3rem; font-weight: 600;') MR
            h4 Michael Rodriguez
            p CTO &amp; Co-founder
            .team-social
              a(href='#'): i.bi.bi-linkedin
              a(href='#'): i.bi.bi-twitter-x
        .col-lg-3.col-md-6
          .team-card.animate-on-scroll.delay-2
            .team-card-image(style='background: linear-gradient(135deg, #2ECC71, #58D68D); display: flex; align-items: center; justify-content: center; color: white; font-size: 3rem; font-weight: 600;') SW
            h4 Sarah Williams
            p VP of Product
            .team-social
              a(href='#'): i.bi.bi-linkedin
              a(href='#'): i.bi.bi-twitter-x
        .col-lg-3.col-md-6
          .team-card.animate-on-scroll.delay-3
            .team-card-image(style='background: linear-gradient(135deg, #FF6B6B, #FF8585); display: flex; align-items: center; justify-content: center; color: white; font-size: 3rem; font-weight: 600;') DK
            h4 David Kim
            p VP of Customer Success
            .team-social
              a(href='#'): i.bi.bi-linkedin
              a(href='#'): i.bi.bi-twitter-x

  section.cta-section
    .container
      .cta-content
        h2 Join Our Growing Team
        p We're always looking for talented people who share our passion.
        a.btn.btn-lg(href='#' style='background: white; color: var(--ss-primary);') View Open Positions
