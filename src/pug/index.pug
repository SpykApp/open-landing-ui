extends layouts/base

block vars
  - activePage = 'home'
  - pageTitle = 'Smart Workforce Management Platform'
  - pageDescription = 'SpykApps - The all-in-one workforce management platform for staffing, scheduling, payroll, and compliance. Streamline your operations today.'

block content

  //- HERO
  section.hero#hero
    .container
      .row.align-items-center
        .col-lg-6
          .hero-content
            .hero-badge
              i.bi.bi-star-fill
              span Rated #1 Workforce Platform 2024
            h1.display-title
              | Workforce Management&nbsp;
              span.text-gradient Made Simple
            p.lead Streamline scheduling, automate payroll, and ensure compliance—all from one powerful platform. Join 5,000+ companies transforming how they manage their workforce.
            .hero-buttons
              a.btn.btn-primary.btn-lg(href='#')
                i.bi.bi-play-circle
                |  Book a Demo
              a.btn.btn-secondary.btn-lg(href='#') Start Free Trial
            .hero-stats
              .hero-stat
                span.hero-stat-value.counter(data-target='5000') 0
                span.hero-stat-label Active Companies
              .hero-stat
                span.hero-stat-value
                  span.counter(data-target='98') 0
                  | %
                span.hero-stat-label Customer Satisfaction
              .hero-stat
                span.hero-stat-value
                  span.counter(data-target='35') 0
                  | %
                span.hero-stat-label Time Saved

        .col-lg-6
          .hero-image
            .hero-image-wrapper
              svg(viewBox='0 0 600 450' fill='none' xmlns='http://www.w3.org/2000/svg' class='img-fluid')
                rect(width='600' height='450' rx='16' fill='#F8F9FA')
                rect(x='0' y='0' width='180' height='450' rx='16' fill='#1A1A2E')
                circle(cx='50' cy='40' r='16' fill='#6B5CE7')
                rect(x='76' y='32' width='80' height='8' rx='4' fill='#4A4A6A')
                rect(x='76' y='44' width='50' height='6' rx='3' fill='#3A3A5A')
                rect(x='24' y='90' width='132' height='36' rx='8' fill='#6B5CE7')
                rect(x='24' y='140' width='132' height='36' rx='8' fill='#2D2D44')
                rect(x='24' y='190' width='132' height='36' rx='8' fill='#2D2D44')
                rect(x='24' y='240' width='132' height='36' rx='8' fill='#2D2D44')
                rect(x='200' y='20' width='380' height='60' rx='12' fill='white' stroke='#E9ECEF' stroke-width='2')
                rect(x='220' y='40' width='120' height='20' rx='6' fill='#E9ECEF')
                circle(cx='540' cy='50' r='16' fill='#6B5CE7' opacity='0.2')
                rect(x='200' y='100' width='180' height='100' rx='12' fill='white' stroke='#E9ECEF' stroke-width='2')
                rect(x='220' y='120' width='60' height='8' rx='4' fill='#6B5CE7')
                rect(x='220' y='140' width='100' height='24' rx='6' fill='#1A1A2E')
                rect(x='220' y='175' width='80' height='6' rx='3' fill='#2ECC71')
                rect(x='400' y='100' width='180' height='100' rx='12' fill='white' stroke='#E9ECEF' stroke-width='2')
                rect(x='420' y='120' width='60' height='8' rx='4' fill='#FF6B6B')
                rect(x='420' y='140' width='100' height='24' rx='6' fill='#1A1A2E')
                rect(x='420' y='175' width='80' height='6' rx='3' fill='#4A90E2')
                rect(x='200' y='220' width='380' height='210' rx='12' fill='white' stroke='#E9ECEF' stroke-width='2')
                rect(x='220' y='240' width='80' height='8' rx='4' fill='#1A1A2E')
                path(d='M240 380 L300 340 L360 360 L420 300 L480 320 L540 280' stroke='#6B5CE7' stroke-width='3' stroke-linecap='round' fill='none')
                path(d='M240 380 L300 340 L360 360 L420 300 L480 320 L540 280 L540 400 L240 400 Z' fill='url(#chart-gradient)' opacity='0.2')
                defs
                  linearGradient(id='chart-gradient' x1='390' y1='280' x2='390' y2='400' gradientUnits='userSpaceOnUse')
                    stop(stop-color='#6B5CE7')
                    stop(offset='1' stop-color='#6B5CE7' stop-opacity='0')
              .hero-floating-card.card-1
                .icon.bg-success-soft: i.bi.bi-check-circle-fill
                .text
                  strong Payroll Processed
                  span.text-muted $42,500 this week
              .hero-floating-card.card-2
                .icon.bg-primary-soft: i.bi.bi-people-fill
                .text
                  strong 128 Employees
                  span.text-muted Active today

  //- LOGO STRIP
  section.logo-strip
    .container
      p.logo-strip-title Trusted by leading companies worldwide
      .logo-strip-items
        .logo-strip-item
          svg(width='120' height='32' viewBox='0 0 120 32' fill='none')
            rect(width='32' height='32' rx='6' fill='#1A1A2E')
            path(d='M16 8L24 24H8L16 8Z' fill='#6B5CE7')
            text(x='40' y='22' font-family='Poppins, sans-serif' font-size='14' font-weight='600' fill='#1A1A2E') Acme Inc
        .logo-strip-item
          svg(width='120' height='32' viewBox='0 0 120 32' fill='none')
            circle(cx='16' cy='16' r='14' stroke='#1A1A2E' stroke-width='3')
            circle(cx='16' cy='16' r='6' fill='#FF6B6B')
            text(x='40' y='22' font-family='Poppins, sans-serif' font-size='14' font-weight='600' fill='#1A1A2E') Globex
        .logo-strip-item
          svg(width='120' height='32' viewBox='0 0 120 32' fill='none')
            rect(x='2' y='2' width='28' height='28' rx='4' fill='#4A90E2')
            rect(x='8' y='8' width='8' height='8' fill='white')
            rect(x='16' y='16' width='8' height='8' fill='white')
            text(x='40' y='22' font-family='Poppins, sans-serif' font-size='14' font-weight='600' fill='#1A1A2E') TechFlow
        .logo-strip-item
          svg(width='120' height='32' viewBox='0 0 120 32' fill='none')
            path(d='M16 4L28 28H4L16 4Z' fill='#2ECC71')
            text(x='40' y='22' font-family='Poppins, sans-serif' font-size='14' font-weight='600' fill='#1A1A2E') Initech
        .logo-strip-item
          svg(width='130' height='32' viewBox='0 0 130 32' fill='none')
            rect(width='32' height='32' rx='16' fill='#F1C40F')
            path(d='M16 8V24M8 16H24' stroke='white' stroke-width='3' stroke-linecap='round')
            text(x='40' y='22' font-family='Poppins, sans-serif' font-size='14' font-weight='600' fill='#1A1A2E') Massive

  //- FEATURES
  section.features.bg-light-soft#features
    .container
      .section-title
        span.subtitle Features
        h2 Everything You Need to Manage Your Workforce
        p Powerful tools designed to simplify every aspect of workforce management, from scheduling to payroll and beyond.
      .row.g-4
        -
          var featureCards = [
            { icon: 'calendar-check', color: 'purple', title: 'Smart Scheduling',       desc: 'AI-powered scheduling that optimizes shifts based on availability, skills, and labor laws. Reduce scheduling conflicts by 90%.', delay: '' },
            { icon: 'clock-history',  color: 'blue',   title: 'Time Tracking',          desc: 'Accurate time tracking with GPS verification, biometric options, and seamless mobile clock-in. No more buddy punching.', delay: 'delay-1' },
            { icon: 'cash-stack',     color: 'green',  title: 'Automated Payroll',      desc: 'Process payroll in minutes with automatic tax calculations, direct deposits, and compliance with local regulations.', delay: 'delay-2' },
            { icon: 'shield-check',   color: 'orange', title: 'Compliance Management', desc: 'Stay compliant with labor laws, certifications, and training requirements. Get alerts before credentials expire.', delay: 'delay-1' },
            { icon: 'graph-up-arrow', color: 'pink',   title: 'Analytics & Reports',   desc: 'Real-time insights into labor costs, productivity, and workforce trends. Make data-driven decisions effortlessly.', delay: 'delay-2' },
            { icon: 'phone',          color: 'teal',   title: 'Mobile App',            desc: 'Empower your team with a mobile app for schedules, time-off requests, shift swaps, and instant notifications.', delay: 'delay-3' }
          ]
        each card in featureCards
          .col-md-6.col-lg-4
            div(class=`feature-card animate-on-scroll ${card.delay}`)
              div(class=`feature-icon icon-${card.color}`)
                i(class=`bi bi-${card.icon}`)
              h4= card.title
              p= card.desc
      .text-center.mt-5
        a.btn.btn-outline-primary(href='features.html')
          | View All Features&nbsp;
          i.bi.bi-arrow-right

  //- HOW IT WORKS
  section.steps-section.bg-pattern#how-it-works
    .container
      .section-title
        span.subtitle How It Works
        h2 Get Started in 3 Simple Steps
        p Setting up SpykApps takes just minutes. Here's how easy it is to transform your workforce management.
      .row
        .col-md-4
          .step-item.animate-on-scroll
            .step-number 1
            .step-connector
            h4 Create Your Account
            p Sign up in seconds and import your employee data from spreadsheets or existing systems.
        .col-md-4
          .step-item.animate-on-scroll.delay-1
            .step-number 2
            .step-connector
            h4 Configure Your Settings
            p Set up pay rules, shift templates, and compliance requirements tailored to your business.
        .col-md-4
          .step-item.animate-on-scroll.delay-2
            .step-number 3
            h4 Start Managing
            p Begin scheduling, tracking time, and processing payroll—all from one intuitive dashboard.

  //- INTEGRATIONS
  section.integrations#integrations
    .container
      .section-title
        span.subtitle Integrations
        h2 Connects With Your Favorite Tools
        p SpykApps integrates seamlessly with the tools you already use, ensuring a smooth workflow.
      .integration-grid.animate-on-scroll
        .integration-item(title='Slack')
          svg(viewBox='0 0 48 48' fill='none' xmlns='http://www.w3.org/2000/svg')
            path(d='M18.5 10C18.5 7.5 16.5 5.5 14 5.5C11.5 5.5 9.5 7.5 9.5 10C9.5 12.5 11.5 14.5 14 14.5H18.5V10Z' fill='#E01E5A')
            path(d='M20 10C20 12.5 22 14.5 24.5 14.5C27 14.5 29 12.5 29 10V5.5H24.5C22 5.5 20 7.5 20 10Z' fill='#36C5F0')
            path(d='M24.5 20C22 20 20 22 20 24.5C20 27 22 29 24.5 29H29V24.5C29 22 27 20 24.5 20Z' fill='#2EB67D')
            path(d='M10 24.5C10 22 12 20 14.5 20C17 20 19 22 19 24.5V29H14.5C12 29 10 27 10 24.5Z' fill='#ECB22E')
            path(d='M14.5 38.5C17 38.5 19 36.5 19 34C19 31.5 17 29.5 14.5 29.5H10V34C10 36.5 12 38.5 14.5 38.5Z' fill='#E01E5A')
            path(d='M24.5 29.5C22 29.5 20 31.5 20 34V38.5H24.5C27 38.5 29 36.5 29 34C29 31.5 27 29.5 24.5 29.5Z' fill='#36C5F0')
            path(d='M38.5 34C38.5 36.5 36.5 38.5 34 38.5C31.5 38.5 29.5 36.5 29.5 34V29.5H34C36.5 29.5 38.5 31.5 38.5 34Z' fill='#2EB67D')
            path(d='M34 20C31.5 20 29.5 22 29.5 24.5C29.5 27 31.5 29 34 29H38.5V24.5C38.5 22 36.5 20 34 20Z' fill='#ECB22E')
        .integration-item(title='Google Workspace')
          svg(viewBox='0 0 48 48' fill='none' xmlns='http://www.w3.org/2000/svg')
            path(d='M43.6 20.1H42V20H24V28H35.3C33.7 32.4 29.2 35.5 24 35.5C17.4 35.5 12 30.1 12 23.5C12 16.9 17.4 11.5 24 11.5C27.1 11.5 29.9 12.7 32 14.6L37.7 8.9C34.1 5.5 29.3 3.5 24 3.5C13 3.5 4 12.5 4 23.5C4 34.5 13 43.5 24 43.5C35 43.5 44 34.5 44 23.5C44 22.3 43.9 21.2 43.6 20.1Z' fill='#FFC107')
            path(d='M6.3 14.1L12.9 18.9C14.6 14.8 18.9 11.9 24 11.9C27.1 11.9 29.9 13.1 32 15L37.7 9.3C34.1 5.9 29.3 3.9 24 3.9C16.3 3.9 9.7 8.1 6.3 14.1Z' fill='#FF3D00')
            path(d='M24 44C29.2 44 33.9 42.1 37.5 38.9L31.3 33.5C29.3 35 26.8 35.9 24 35.9C18.9 35.9 14.4 32.9 12.7 28.5L6.1 33.5C9.5 39.7 16.2 44 24 44Z' fill='#4CAF50')
            path(d='M43.6 20.1H42V20H24V28H35.3C34.5 30.1 33.2 31.9 31.3 33.2L37.5 38.6C37.1 39 44 34 44 23.5C44 22.3 43.9 21.2 43.6 20.1Z' fill='#1976D2')
        .integration-item(title='Microsoft 365')
          svg(viewBox='0 0 48 48' fill='none' xmlns='http://www.w3.org/2000/svg')
            rect(x='6' y='6' width='17' height='17' fill='#F25022')
            rect(x='25' y='6' width='17' height='17' fill='#7FBA00')
            rect(x='6' y='25' width='17' height='17' fill='#00A4EF')
            rect(x='25' y='25' width='17' height='17' fill='#FFB900')
        .integration-item(title='Quickbooks')
          svg(viewBox='0 0 48 48' fill='none' xmlns='http://www.w3.org/2000/svg')
            circle(cx='24' cy='24' r='20' fill='#2CA01C')
            path(d='M18 18V30H21V21H24C26.8 21 29 23.2 29 26C29 28.8 26.8 31 24 31H21V34H24C28.4 34 32 30.4 32 26C32 21.6 28.4 18 24 18H18Z' fill='white')
            path(d='M27 30V18H24V27H21C18.2 27 16 24.8 16 22C16 19.2 18.2 17 21 17H24V14H21C16.6 14 13 17.6 13 22C13 26.4 16.6 30 21 30H27Z' fill='white')
        .integration-item(title='Zoom')
          svg(viewBox='0 0 48 48' fill='none' xmlns='http://www.w3.org/2000/svg')
            rect(x='4' y='10' width='40' height='28' rx='8' fill='#2D8CFF')
            path(d='M32 24L40 18V30L32 24Z' fill='white')
            rect(x='8' y='16' width='22' height='16' rx='3' fill='white')
        .integration-item(title='Salesforce')
          svg(viewBox='0 0 48 48' fill='none' xmlns='http://www.w3.org/2000/svg')
            ellipse(cx='24' cy='26' rx='18' ry='14' fill='#00A1E0')
            ellipse(cx='14' cy='22' rx='8' ry='8' fill='#00A1E0')
            ellipse(cx='34' cy='22' rx='8' ry='8' fill='#00A1E0')
            ellipse(cx='24' cy='16' rx='10' ry='8' fill='#00A1E0')
        .integration-item(title='ADP')
          svg(viewBox='0 0 48 48' fill='none' xmlns='http://www.w3.org/2000/svg')
            rect(width='48' height='48' rx='8' fill='#D32F2F')
            text(x='8' y='32' font-family='Arial Black' font-size='20' font-weight='900' fill='white') ADP
        .integration-item(title='Zapier')
          svg(viewBox='0 0 48 48' fill='none' xmlns='http://www.w3.org/2000/svg')
            path(d='M28 4H20V18L8 10L4 16L16 24L4 32L8 38L20 30V44H28V30L40 38L44 32L32 24L44 16L40 10L28 18V4Z' fill='#FF4A00')
      p.text-center.mt-4.text-white-50 And 50+ more integrations available

  //- TESTIMONIALS
  section.testimonials#testimonials
    .container
      .section-title
        span.subtitle Testimonials
        h2 What Our Customers Say
        p Join thousands of satisfied customers who have transformed their workforce management with SpykApps.
      .testimonial-slider
        .testimonial-track
          -
            var testimonials = [
              { initials: 'SM', gradient: '#6B5CE7, #8B7DF2', name: 'Sarah Mitchell',   role: 'HR Director, TechCorp Solutions',         stars: 5, text: '"SpykApps has completely transformed how we manage our 200+ employees. Scheduling that used to take hours now takes minutes. The ROI was immediate."' },
              { initials: 'MR', gradient: '#FF6B6B, #FF8585', name: 'Michael Rodriguez', role: 'Operations Manager, HealthFirst Clinic',   stars: 5, text: '"The compliance features alone are worth the investment. We\'ve avoided multiple potential violations and the peace of mind is invaluable."' },
              { initials: 'EW', gradient: '#4A90E2, #6BA8EE', name: 'Emily Watson',      role: 'General Manager, Urban Eats Restaurant',  stars: 5, text: '"Our employees love the mobile app. Shift swaps, time-off requests, and schedule viewing are all so easy. It\'s reduced our admin overhead significantly."' },
              { initials: 'DK', gradient: '#2ECC71, #58D68D', name: 'David Kim',         role: 'CFO, Premier Staffing Agency',             stars: 5, text: '"Switching to SpykApps cut our payroll processing time by 75%. The automatic calculations and tax compliance have eliminated errors entirely."' },
              { initials: 'LP', gradient: '#F1C40F, #F4D03F', name: 'Lisa Patel',        role: 'VP of People, CloudNine Software',         stars: 5, text: '"The analytics dashboard gives us insights we never had before. We\'ve optimized our labor costs and improved employee satisfaction scores."' },
              { initials: 'JT', gradient: '#9B59B6, #BB8FCE', name: 'James Thompson',    role: 'Owner, Thompson Security Services',        stars: 5, text: '"Implementation was seamless. The support team helped us migrate from our old system in just two weeks. Best decision we\'ve made this year."' }
            ]
          each t in testimonials
            .testimonial-card
              .testimonial-card-inner
                .testimonial-rating
                  - for(var i=0; i<t.stars; i++)
                    i.bi.bi-star-fill
                p.testimonial-text= t.text
                .testimonial-author
                  .testimonial-avatar(style=`background: linear-gradient(135deg, ${t.gradient}); display: flex; align-items: center; justify-content: center; color: white; font-weight: 600;`)= t.initials
                  .testimonial-info
                    h5= t.name
                    p= t.role
        .testimonial-nav
          button.testimonial-nav-btn.testimonial-prev(aria-label='Previous testimonial'): i.bi.bi-chevron-left
          button.testimonial-nav-btn.testimonial-next(aria-label='Next testimonial'): i.bi.bi-chevron-right
        .testimonial-dots

  //- PRICING PREVIEW
  section.pricing#pricing
    .container
      .section-title
        span.subtitle Pricing
        h2 Simple, Transparent Pricing
        p Choose the plan that fits your business. All plans include a 14-day free trial with no credit card required.
      .pricing-toggle
        span.pricing-toggle-label.active(data-period='monthly') Monthly
        .pricing-toggle-switch
        span.pricing-toggle-label(data-period='yearly') Yearly
        span.pricing-save Save 20%
      .row.g-4.justify-content-center
        .col-lg-4.col-md-6
          .pricing-card.animate-on-scroll
            span.pricing-plan Starter
            h3 For Small Teams
            .pricing-price
              span.pricing-amount.price-monthly
                sup $
                | 29
              span.pricing-amount.price-yearly(style='display:none;')
                sup $
                | 23
              span.pricing-period per user / month
            p.pricing-desc Perfect for small businesses just getting started.
            ul.pricing-features
              li: i.bi.bi-check-circle-fill
                |  Up to 25 employees
              li: i.bi.bi-check-circle-fill
                |  Basic scheduling
              li: i.bi.bi-check-circle-fill
                |  Time tracking
              li: i.bi.bi-check-circle-fill
                |  Mobile app access
              li: i.bi.bi-check-circle-fill
                |  Email support
              li.disabled: i.bi.bi-x-circle
                |  Payroll processing
              li.disabled: i.bi.bi-x-circle
                |  Advanced analytics
            a.btn.btn-outline-primary(href='#') Start Free Trial
        .col-lg-4.col-md-6
          .pricing-card.popular.animate-on-scroll.delay-1
            span.pricing-badge Most Popular
            span.pricing-plan Professional
            h3 For Growing Teams
            .pricing-price
              span.pricing-amount.price-monthly
                sup $
                | 59
              span.pricing-amount.price-yearly(style='display:none;')
                sup $
                | 47
              span.pricing-period per user / month
            p.pricing-desc Everything you need to manage and scale your workforce.
            ul.pricing-features
              li: i.bi.bi-check-circle-fill
                |  Up to 100 employees
              li: i.bi.bi-check-circle-fill
                |  Advanced scheduling
              li: i.bi.bi-check-circle-fill
                |  Time tracking + GPS
              li: i.bi.bi-check-circle-fill
                |  Payroll processing
              li: i.bi.bi-check-circle-fill
                |  Compliance alerts
              li: i.bi.bi-check-circle-fill
                |  Analytics dashboard
              li: i.bi.bi-check-circle-fill
                |  Priority support
            a.btn.btn-primary(href='#') Start Free Trial
        .col-lg-4.col-md-6
          .pricing-card.animate-on-scroll.delay-2
            span.pricing-plan Enterprise
            h3 For Large Organizations
            .pricing-price
              span.pricing-amount Custom
              span.pricing-period tailored to your needs
            p.pricing-desc Custom solutions for enterprise-level needs.
            ul.pricing-features
              li: i.bi.bi-check-circle-fill
                |  Unlimited employees
              li: i.bi.bi-check-circle-fill
                |  Custom integrations
              li: i.bi.bi-check-circle-fill
                |  Advanced security
              li: i.bi.bi-check-circle-fill
                |  Dedicated success manager
              li: i.bi.bi-check-circle-fill
                |  Custom reporting
              li: i.bi.bi-check-circle-fill
                |  SLA guarantee
              li: i.bi.bi-check-circle-fill
                |  On-site training
            a.btn.btn-dark(href='contact.html') Contact Sales

  //- FAQ
  section.faq.bg-light-soft#faq
    .container
      .section-title
        span.subtitle FAQ
        h2 Frequently Asked Questions
        p Find answers to common questions about SpykApps. Can't find what you're looking for? Contact our support team.
      .faq-grid
        .accordion#faqAccordion
          -
            var faqs = [
              { id: 'faq1', open: true,  q: 'How long does it take to set up SpykApps?',                    a: 'Most businesses are up and running within a day. You can import existing employee data via CSV or connect to your current HR system. Our onboarding team provides personalized setup assistance to ensure a smooth transition.' },
              { id: 'faq2', open: false, q: 'Is my data secure with SpykApps?',                            a: 'Absolutely. We use bank-level 256-bit SSL encryption, SOC 2 Type II certified data centers, and regular security audits. Your data is backed up daily and we offer two-factor authentication for all accounts.' },
              { id: 'faq3', open: false, q: 'Can I integrate SpykApps with my existing payroll provider?',  a: 'Yes! SpykApps integrates with major payroll providers including ADP, Paychex, Gusto, and QuickBooks. You can also use our built-in payroll processing or export data in various formats for manual import.' },
              { id: 'faq4', open: false, q: 'What happens after the free trial ends?',                       a: 'After your 14-day trial, you\'ll be prompted to choose a plan. Your data is preserved for 30 days if you need more time to decide. No credit card is required during the trial, so you won\'t be automatically charged.' },
              { id: 'faq5', open: false, q: 'Do you offer training for my team?',                            a: 'Yes, we offer comprehensive training resources including video tutorials, documentation, and live webinars. Professional and Enterprise plans include dedicated onboarding sessions, and Enterprise customers receive on-site training options.' },
              { id: 'faq6', open: false, q: 'Can employees access SpykApps on their phones?',              a: 'Yes! Our mobile app is available for iOS and Android. Employees can view schedules, clock in/out, request time off, swap shifts, and receive notifications—all from their smartphones.' }
            ]
          each faq in faqs
            div(class=`accordion-item animate-on-scroll`)
              h2.accordion-header
                button(class=`accordion-button${faq.open ? '' : ' collapsed'}` type='button' data-bs-toggle='collapse' data-bs-target=`#${faq.id}`)= faq.q
              div(id=faq.id class=`accordion-collapse collapse${faq.open ? ' show' : ''}` data-bs-parent='#faqAccordion')
                .accordion-body= faq.a

  //- BLOG PREVIEW
  section.blog-preview#blog
    .container
      .section-title
        span.subtitle Blog
        h2 Latest from Our Blog
        p Stay updated with workforce management tips, industry news, and product updates.
      .row.g-4
        -
          var blogPosts = [
            { category: 'Scheduling', date: 'Nov 15, 2024', read: '5 min read', title: '10 Strategies to Reduce Employee Scheduling Conflicts', excerpt: 'Learn proven techniques to minimize scheduling conflicts and improve team satisfaction.', delay: '' },
            { category: 'Compliance', date: 'Nov 10, 2024', read: '7 min read', title: '2024 Labor Law Updates Every Employer Should Know', excerpt: 'Stay compliant with the latest changes in labor regulations and requirements.', delay: 'delay-1' },
            { category: 'Productivity', date: 'Nov 5, 2024', read: '6 min read', title: 'How Automation is Transforming HR Operations', excerpt: 'Discover how modern HR teams are using automation to save time and reduce errors.', delay: 'delay-2' }
          ]
        each post in blogPosts
          .col-lg-4.col-md-6
            article(class=`blog-card animate-on-scroll ${post.delay}`)
              .blog-card-image
                svg(viewBox='0 0 400 220' fill='none' xmlns='http://www.w3.org/2000/svg')
                  rect(width='400' height='220' fill='#F0F2F5')
                  rect(x='40' y='40' width='320' height='140' rx='8' fill='#E9ECEF')
                  circle(cx='200' cy='110' r='40' fill='#6B5CE7' opacity='0.3')
                  path(d='M180 110L195 120L220 95' stroke='#6B5CE7' stroke-width='4' stroke-linecap='round' stroke-linejoin='round')
                span.blog-card-category= post.category
              .blog-card-body
                .blog-card-meta
                  span: i.bi.bi-calendar3
                    |  #{post.date}
                  span: i.bi.bi-clock
                    |  #{post.read}
                h4: a(href='blog-single.html')= post.title
                p= post.excerpt
                a.blog-card-link(href='blog-single.html')
                  | Read More&nbsp;
                  i.bi.bi-arrow-right
      .text-center.mt-5
        a.btn.btn-outline-primary(href='blog.html')
          | View All Articles&nbsp;
          i.bi.bi-arrow-right

