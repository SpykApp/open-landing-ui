//- Logo SVG mixin
//- Usage: +logo(40, 40, 'unique-gradient-id')
mixin logo(w=40, h=40, gradId='logo-grad')
  svg(width=w height=h viewBox='0 0 40 40' fill='none' xmlns='http://www.w3.org/2000/svg')
    rect(width='40' height='40' rx='10' fill=`url(#${gradId})`)
    path(d='M10 15h20M10 20h15M10 25h10' stroke='white' stroke-width='2.5' stroke-linecap='round')
    defs
      linearGradient(id=gradId x1='0' y1='0' x2='40' y2='40' gradientUnits='userSpaceOnUse')
        stop(stop-color='#6B5CE7')
        stop(offset='1' stop-color='#8B7DF2')
